{
  "version": "2025-10-13",
  "notes": "Editable. Controls elective validation and degree bucket rules.",
  "forbidden": {
    "prefixes": [
      "MTEC",
      "ETEC"
    ],
    "course_ids": [
      "MATH 3630",
      "MATH 4100",
      "MATH 4190",
      "MATH 4350",
      "MATH 4660",
      "BMEN 4390",
      "BMEN 5390"
    ]
  },
  "buckets": {
    "GenEd_AH": {
      "catalog_file": "AH_catalog.normalized.csv",
      "min_count": 3,
      "must_include_one_of": [
        "PHIL 3340",
        "PHIL 2030"
      ]
    },
    "GenEd_SS": {
      "catalog_file": "SS_catalog.normalized.csv",
      "min_count": 3,
      "must_include_one_of": [
        "ECON 2010",
        "ECON 2020"
      ]
    },
    "TechElective": {
      "catalog_file": "TE_catalog.normalized.csv",
      "min_count": 3
    }
  },
  "core_curriculum_policy": {
    "dept_cap": 2,
    "cap_applies_to": [
      "GenEd_AH",
      "GenEd_SS"
    ],
    "max_from_single_department": 2,
    "selection_count_note": "Students choose 4 Core Curriculum courses total; enforce department cap across these selections."
  }
}